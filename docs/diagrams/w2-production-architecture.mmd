flowchart LR

%% ============================================================
%% CLIENT
%% ============================================================
subgraph CLIENT["CLINICIAN + CO-PILOT WEB"]
  direction TB
  UI["Upload &amp; Review UI<br/>Question UI<br/>/api/status panel"]
end

%% ============================================================
%% API + WORKERS (single FastAPI service)
%% ============================================================
subgraph APP["FASTAPI + LANGGRAPH SERVICE"]
  direction TB
  AUTH["Auth + Patient Guard<br/>FHIR bearer revalidated per request"]
  SUP["Rule-Based Supervisor<br/>typed GraphState<br/>RoutingDecision per transition<br/>closed reason_code enum"]
  EX["intake-extractor<br/>Mistral OCR → deterministic parser<br/>→ vision crop / full-page fallback<br/>ExtractedFact[] append-only"]
  ER["evidence-retriever<br/>structured query or 4o-mini rewriter<br/>patient FHIR + guideline RAG<br/>BM25 + HNSW + RRF + Cohere rerank"]
  AC["answer-composer<br/>two-bundle prompt<br/>strict ClinicalAnswer payload"]
  VER["Verifier (typed rule pipeline)<br/>5 targets · severity-driven action<br/>regen / refuse / block_write / block_log"]
end

%% ============================================================
%% OUTBOX + DRAIN
%% ============================================================
subgraph DRAIN["OUTBOX DRAIN WORKERS"]
  direction TB
  DW["Multi-worker SKIP LOCKED<br/>per-tenant slot table<br/>Observation + Provenance POST<br/>If-None-Exist + round-trip verify<br/>retry → backoff → DLQ"]
end

%% ============================================================
%% POSTGRES (single instance)
%% ============================================================
subgraph DB["POSTGRES — ParadeDB BM25 + pgvector HNSW"]
  direction TB
  OPER["Operational tables (monthly partitioned)<br/>extraction_jobs · extracted_facts<br/>routing_decisions · verification_runs<br/>retrieval_runs · observation_writes<br/>cost_events (per org_id)"]
  QUEUE["Outbox<br/>pending_observation_writes · DLQ"]
  CORPUS["Guideline corpus<br/>guideline_documents · guideline_chunks<br/>chunk_hash UNIQUE"]
  PHI["Compliance schema (insert-only app role)<br/>phi_access_log · monthly partitions<br/>WORM archive export"]
end

%% ============================================================
%% OPENEMR
%% ============================================================
subgraph EMR["OPENEMR (FHIR) — source of truth"]
  direction TB
  PAT["Patient · DocumentReference · Binary"]
  OBS["Observation · Provenance"]
end

%% ============================================================
%% EXTERNAL PROVIDERS
%% ============================================================
subgraph PROV["EXTERNAL ML/LLM PROVIDERS"]
  direction TB
  MISTRAL["Mistral OCR<br/>fallback: Azure DocIntel"]
  OPENAI["OpenAI<br/>gpt-4.1 vision · gpt-4.1 answer<br/>4o-mini rewriter · embedding-3-large"]
  COHERE["Cohere Rerank v3<br/>skip-on-confidence-gap<br/>fallback: Voyage"]
end

%% ============================================================
%% OBSERVABILITY
%% ============================================================
subgraph OBS_STACK["OBSERVABILITY (self-hosted, OTel-native)"]
  direction TB
  OTEL["OTel Collector + OpenLLMetry"]
  BACKENDS["Tempo metadata · Loki · Mimir<br/>Langfuse prompt traces"]
  DASH["Grafana + Alertmanager → PagerDuty<br/>SLO burn · cost · latency · compliance"]
end

%% ============================================================
%% COMPLIANCE ARCHIVE
%% ============================================================
subgraph WORM["COMPLIANCE ARCHIVE (separate AWS account)"]
  direction TB
  S3["S3 Object Lock — COMPLIANCE mode<br/>monthly partition snapshots<br/>retention 6 years 30 days"]
end

%% ============================================================
%% SYNTHETIC MONITORING
%% ============================================================
subgraph SYN["CONTINUOUS SYNTHETIC MONITORING"]
  direction TB
  SMR["Stratified eval · smoke 15min<br/>full hourly · cross-variant nightly"]
end

%% ============================================================
%% PRIMARY EDGES
%% ============================================================

%% Client → API
UI --> AUTH

%% Auth → Supervisor
AUTH --> SUP
AUTH -.FHIR Patient read.-> PAT

%% Document upload path: API stores source in OpenEMR
AUTH -.Binary + DocumentReference<br/>If-None-Exist.-> PAT

%% Supervisor → workers
SUP --> EX
SUP --> ER
SUP --> AC

%% Workers → external providers
EX --> MISTRAL
EX --> OPENAI
ER --> COHERE
ER --> OPENAI
AC --> OPENAI

%% Workers → DB
EX --> OPER
ER --> CORPUS
ER --> OPER
AC --> OPER

%% ER also reads patient FHIR
ER -.patient evidence.-> PAT

%% Verification
EX --> VER
AC --> VER
VER --> OPER
VER -.regenerate / refuse / block.-> SUP

%% Approval → outbox
SUP -.transactional<br/>outbox insert.-> QUEUE

%% Drain → FHIR write
QUEUE --> DW
DW -- POST + round-trip verify --> OBS
DW --> OPER

%% PHI access logging
AUTH -.every PHI access.-> PHI
PHI -.monthly immutable snapshot.-> S3

%% Cost telemetry
MISTRAL -.cost_events.-> OPER
OPENAI -.cost_events.-> OPER
COHERE -.cost_events.-> OPER

%% Observability flows
APP -.OTel spans + logs.-> OTEL
DRAIN -.OTel spans.-> OTEL
OTEL --> BACKENDS
BACKENDS --> DASH

%% Synthetic monitoring drives the system from outside
SMR -.HTTP traffic.-> AUTH
SMR -.eval pass-rate SLO.-> BACKENDS

