# The Railway/OpenEMR image inherits the official OpenEMR runtime and only
# copies fork-identifying docs into /agentforge. Keep the Docker context tiny.

*

!Dockerfile
!railway.toml
!.dockerignore
!.railwayignore
!interface/
!interface/agentforge/
!interface/agentforge/copilot.php
!interface/main/
!interface/main/tabs/
!interface/main/tabs/menu/
!interface/main/tabs/menu/menus/
!interface/main/tabs/menu/menus/standard.json
!interface/main/tabs/menu/menus/front_office.json
!interface/main/tabs/menu/menus/chart_review.json
!interface/main/tabs/menu/menus/answering_service.json
!interface/main/tabs/menu/menus/patient_menus/
!interface/main/tabs/menu/menus/patient_menus/standard.json
!interface/patient_tracker/
!interface/patient_tracker/patient_tracker.php
!library/
!library/globals.inc.php
!src/
!src/Services/
!src/Services/Globals/
!src/Services/Globals/GlobalConnectorsEnum.php
!AUDIT.md
!ARCHITECTURE.md
!USERS.md
!USER.md
!PRESEARCH.md
!DEPLOYMENT_RUNBOOK.md
!DEMO_PLAN.md
!EVAL_PLAN.md
!MVP_AUTH_SCOPE.md
!MVP_STATUS.md
!OPENEMR_VERSION_PIN.md
