COPILOT_API_BASE_URL=https://<copilot-api-domain>
PUBLIC_BASE_URL=https://<copilot-web-domain>

# SMART/OAuth code flow. Use the same OpenEMR client id registered for the web app.
OPENEMR_CLIENT_ID=<openemr-smart-client-id>
OPENEMR_CLIENT_SECRET=<confidential-client-secret>
OPENEMR_TOKEN_AUTH_METHOD=client_secret_basic
OPENEMR_BASE_URL=https://<openemr-domain>
OPENEMR_SITE=default
OPENEMR_SCOPES=openid api:oemr api:fhir fhirUser user/Patient.read user/Practitioner.read user/Observation.read user/Observation.write user/Condition.read user/MedicationRequest.read user/AllergyIntolerance.read user/DocumentReference.read

# Required for encrypting the browser session cookie. Generate a high-entropy value.
COPILOT_SESSION_SECRET=<at-least-32-random-bytes>
COPILOT_COOKIE_SECURE=true
# Required when the Co-Pilot runs inside the OpenEMR tab/frame on a different origin.
COPILOT_COOKIE_SAMESITE=none

# Leave NEXT_PUBLIC_API_BASE_URL unset for the normal Railway deployment.
# The browser will use the same-origin /api proxy instead of calling the API directly.
