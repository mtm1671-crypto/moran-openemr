APP_ENV=local
PHI_MODE=false
PUBLIC_BASE_URL=http://localhost:3000

OPENEMR_BASE_URL=http://localhost:8300
OPENEMR_SITE=default
OPENEMR_FHIR_BASE_URL=http://localhost:8300/apis/default/fhir
OPENEMR_OAUTH_TOKEN_URL=http://localhost:8300/oauth2/default/token
OPENEMR_TLS_VERIFY=false
OPENEMR_REQUEST_TIMEOUT_SECONDS=15
OPENEMR_RETRY_ATTEMPTS=3
OPENEMR_RETRY_BACKOFF_SECONDS=0.25

# Local dev only. Production should use SMART authorization code flow.
OPENEMR_DEV_PASSWORD_GRANT=true
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=
OPENEMR_DEV_USERNAME=admin
OPENEMR_DEV_PASSWORD=pass
OPENEMR_DEV_SCOPES=openid offline_access api:oemr api:fhir user/Patient.read user/Practitioner.read user/Observation.read user/Condition.read user/MedicationRequest.read user/AllergyIntolerance.read user/DocumentReference.read

LLM_PROVIDER=mock
EMBEDDING_PROVIDER=none
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_LLM_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_REASONING_EFFORT=low
OPENAI_MAX_OUTPUT_TOKENS=900
OPENAI_TIMEOUT_SECONDS=45
MODEL_RETRY_ATTEMPTS=2
MODEL_RETRY_BACKOFF_SECONDS=0.5
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_MAX_TOKENS=900
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=AgentForge Clinical Co-Pilot
OPENROUTER_DEMO_DATA_ONLY=false
OPENROUTER_BAA_CONFIRMED=false
OPENROUTER_DATA_POLICY_CONFIRMED=false
MODEL_EVIDENCE_LIMIT=12
DOCUMENT_WORKFLOW_PERSISTENCE_ENABLED=false
ALLOW_PHI_TO_OPENAI=false
OPENAI_BAA_CONFIRMED=false
OPENAI_DATA_POLICY_CONFIRMED=false
ALLOW_PHI_TO_ANTHROPIC=false
ALLOW_PHI_TO_OPENROUTER=false
ALLOW_PHI_TO_LOCAL=true
