APP_ENV=production
PHI_MODE=true
PUBLIC_BASE_URL=https://<copilot-web-domain>
DEV_AUTH_BYPASS=false
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>
ENCRYPTION_KEY=<generate-with-python-cryptography-fernet>
ENCRYPTION_KEY_ID=primary

OPENEMR_BASE_URL=https://<openemr-domain>
OPENEMR_SITE=default
OPENEMR_FHIR_BASE_URL=https://<openemr-domain>/apis/default/fhir
OPENEMR_OAUTH_TOKEN_URL=https://<openemr-domain>/oauth2/default/token
OPENEMR_JWKS_URL=https://<openemr-domain>/oauth2/default/jwk
OPENEMR_JWT_ISSUER=https://<openemr-domain>/oauth2/default
OPENEMR_JWT_AUDIENCE=<smart-client-id>
OPENEMR_TLS_VERIFY=true
OPENEMR_API_LOG_OPTION=1
OPENEMR_REQUEST_TIMEOUT_SECONDS=15
OPENEMR_RETRY_ATTEMPTS=3
OPENEMR_RETRY_BACKOFF_SECONDS=0.25

OPENEMR_DEV_PASSWORD_GRANT=false
OPENEMR_CLIENT_ID=<smart-client-id>
OPENEMR_CLIENT_SECRET=<smart-client-secret>

LLM_PROVIDER=mock
EMBEDDING_PROVIDER=none
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_LLM_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_REASONING_EFFORT=low
OPENAI_MAX_OUTPUT_TOKENS=900
OPENAI_TIMEOUT_SECONDS=45
MODEL_RETRY_ATTEMPTS=2
MODEL_RETRY_BACKOFF_SECONDS=0.5
OCR_PROVIDER=none
OPENAI_OCR_MODEL=gpt-4.1-mini
OPENAI_OCR_DETAIL=high
OPENAI_OCR_MAX_OUTPUT_TOKENS=2500
OPENROUTER_OCR_MODEL=baidu/qianfan-ocr-fast:free
OPENROUTER_OCR_MAX_TOKENS=2500
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_MAX_TOKENS=900
OPENROUTER_SITE_URL=https://<copilot-web-domain>
OPENROUTER_APP_NAME=AgentForge Clinical Co-Pilot
OPENROUTER_DEMO_DATA_ONLY=false
OPENROUTER_BAA_CONFIRMED=false
OPENROUTER_DATA_POLICY_CONFIRMED=false
MODEL_EVIDENCE_LIMIT=12
VECTOR_SEARCH_ENABLED=true
VECTOR_EMBEDDING_PROVIDER=hash
VECTOR_EMBEDDING_DIMENSIONS=256
VECTOR_SEARCH_LIMIT=6
VECTOR_CANDIDATE_LIMIT=200
VECTOR_MIN_SCORE=0.05
VECTOR_INDEX_TTL_DAYS=30
# Use pgvector for production. The json backend is for local/demo fallback only.
VECTOR_INDEX_BACKEND=pgvector
EVIDENCE_CACHE_ENABLED=true
EVIDENCE_CACHE_TTL_SECONDS=300
AGENT_LOOP_MAX_STEPS=10
NIGHTLY_MAINTENANCE_ENABLED=true
NIGHTLY_MAINTENANCE_HOUR_UTC=8
NIGHTLY_REINDEX_ENABLED=false
NIGHTLY_REINDEX_PATIENT_COUNT=100
OPENEMR_SERVICE_ACCOUNT_ENABLED=false
OPENEMR_SERVICE_TOKEN_URL=https://<openemr-domain>/oauth2/default/token
OPENEMR_SERVICE_CLIENT_ID=
OPENEMR_SERVICE_CLIENT_SECRET=
OPENEMR_SERVICE_BEARER_TOKEN=
STRUCTURED_LOGGING_ENABLED=true
AUDIT_PERSISTENCE_REQUIRED=true
CONVERSATION_PERSISTENCE_ENABLED=true
JOB_STATUS_RETENTION_DAYS=30
ALLOW_PHI_TO_OPENAI=false
OPENAI_BAA_CONFIRMED=false
OPENAI_DATA_POLICY_CONFIRMED=false
ALLOW_PHI_TO_ANTHROPIC=false
ALLOW_PHI_TO_OPENROUTER=false
ALLOW_PHI_TO_LOCAL=false

CONVERSATION_RETENTION_DAYS=30
REINDEX_IDEMPOTENCY_SECONDS=120
